    "jsonwebtoken": "^9.0.3",
    "mssql": "^12.2.1",
    "twilio": "^5.13.0"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.10",
    "@types/mssql": "^9.1.9",
    "@types/node": "^22.13.14",
    "typescript": "^5.8.2"
  }
}
